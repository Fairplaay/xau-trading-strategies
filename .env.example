# AI Trading Bot - Variables de entorno
# Copia este archivo como .env y completa los valores

# === OBLIGATORIO ===
# Obtén tu API key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-tu-api-key-aqui

# === MODELO + PARÁMETROS IA ===
# Formato: provider/model:variant
MODEL_NAME=meta-llama/llama-3.2-3b-instruct:free

# Parámetros de la IA (opcionales, tienen defaults)
# temperature: 0.0-2.0 (0.1 = preciso, 2.0 = creativo)
TEMPERATURE=0.1

# max_tokens: cuántos tokens puede retornar (20 es suficiente para BUY/SELL)
MAX_TOKENS=20

# reasoning_effort: low/medium/high (low = rápido, no necesitamos análisis profundo)
REASONING_EFFORT=low

# === OPCIONALES ===
# Símbolo a tradear (default: XAUUSD)
#SYMBOL=XAUUSD

# Timeframe (default: M1)
#TIMEFRAME=M1

# Intervalo de check en segundos (default: 60)
#CHECK_INTERVAL=60

# Volumen por operación (default: 0.01)
#VOLUME=0.01

# MT5 - Desviación máxima en pips (default: 20)
#DEVIATION=20

# === MT5 (opcional - si no se usa, conectar manualmente) ===
#MT5_ACCOUNT=12345678
#MT5_PASSWORD=tu_password
#MT5_SERVER=YourServer

# === EA File Connector (lee xau_data.json, escribe xau_commands.json) ===
# Activa esto para usar el EA como fuente de datos y ejecutor de órdenes
#USE_EA_FILE=true
#EA_FILE_PATH=  # opcional, ruta donde están los archivos JSON del EA